# ============================================================================
# Environment Configuration for Artellect Backend
# Copy this file to .env and configure for your environment
# ============================================================================

# Debug Mode (true/false)
DEBUG=false

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Application
API_TITLE=Artellect AI Backend
API_VERSION=2.0.0

# Security
# Generate a strong random key for production: python -c "import secrets; print(secrets.token_urlsafe(32))"
ARTELLECT_SECRET_KEY=dev-secret-key-change-in-production

# Database
ARTELLECT_DATA_DIR=./Backend/app/data
ARTELLECT_UPLOAD_DIR=./Backend/app/uploads

# CORS Configuration
# Comma-separated list of allowed origins
ARTELLECT_CORS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Upload Configuration
MAX_UPLOAD_SIZE=10485760

# Email Configuration (for future use)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
